# Database Configuration
# Option 1: Use DATABASE_URL (recommended for Gitpod/production)
DATABASE_URL=postgresql://url_user:url_password@localhost:5432/url_shortener

# Option 2: Use individual variables (for local development)
# DB_USER=postgres
# DB_HOST=localhost
# DB_NAME=stoik_test
# DB_PASSWORD=password
# DB_PORT=5432

# Server Configuration
PORT=3001
NODE_ENV=development

# Security (optional)
# CORS_ORIGIN=http://localhost:3000
